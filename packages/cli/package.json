{
  "name": "@lykta/cli",
  "version": "0.3.1",
  "description": "CLI tool for inspecting, diffing, and explaining Solana transactions.",
  "type": "module",
  "bin": {
    "lykta": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lykta/core": "workspace:*",
    "@coral-xyz/anchor": "^0.30.0",
    "@google/genai": "^0.7.0",
    "@solana/web3.js": "^1.95.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
