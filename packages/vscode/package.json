{
  "name": "@lykta/vscode",
  "displayName": "Lykta",
  "description": "Solana developer observability — CPI graphs, compute unit flamegraphs, account diffs, and error explanations inside VS Code.",
  "version": "0.1.0",
  "publisher": "lykta",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other", "Debuggers"],
  "keywords": ["solana", "anchor", "blockchain", "debugging", "developer-tools"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lykta.inspectTransaction",
        "title": "Lykta: Inspect Transaction"
      },
      {
        "command": "lykta.showCpiGraph",
        "title": "Lykta: Show CPI Graph"
      },
      {
        "command": "lykta.showAccountDiff",
        "title": "Lykta: Show Account Diff"
      },
      {
        "command": "lykta.showCuFlamegraph",
        "title": "Lykta: Show Compute Unit Flamegraph"
      }
    ],
    "configuration": {
      "title": "Lykta",
      "properties": {
        "lykta.rpcUrl": {
          "type": "string",
          "default": "https://api.devnet.solana.com",
          "description": "RPC URL used to fetch transactions."
        },
        "lykta.cluster": {
          "type": "string",
          "enum": ["mainnet", "devnet", "localnet", "custom"],
          "default": "devnet",
          "description": "Default cluster to query."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --dts --sourcemap --external vscode",
    "dev": "tsup src/extension.ts --format cjs --sourcemap --watch --external vscode",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lykta/core": "workspace:*",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
