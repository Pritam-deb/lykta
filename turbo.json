{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "components/**", "tsconfig.json", "package.json", "next.config.*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["HELIUS_RPC_URL"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false,
      "env": ["HELIUS_RPC_URL"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**", "fixtures/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
